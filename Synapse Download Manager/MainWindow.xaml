<Window x:Class="Synapse_Download_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Download Manager 2.5" Height="650" Width="1000"
        Background="#F3F3F3"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="#0078D7"
        BorderThickness="1">

    <Window.Resources>
        <!-- Google Fonts Emulation (Requires local installation or Resource embedding) -->
        <FontFamily x:Key="Inter">Inter, Segoe UI, sans-serif</FontFamily>
        <FontFamily x:Key="JetBrainsMono">JetBrains Mono, Consolas, monospace</FontFamily>
        <FontFamily x:Key="MaterialSymbols">Segoe MDL2 Assets</FontFamily>

        <!-- Style for Material Icons -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MaterialSymbols}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Toolbar Button Template -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent" 
                                BorderThickness="1"
                                x:Name="border">
                            <StackPanel VerticalAlignment="Center">
                                <ContentPresenter x:Name="content" HorizontalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Tag}" 
                                           FontSize="9" 
                                           Foreground="#333" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,4,0,0"
                                           FontWeight="Medium"
                                           FontFamily="{StaticResource Inter}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TitleBar Button Style -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu Bar Button Style -->
        <Style x:Key="MenuBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontFamily" Value="{StaticResource Inter}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <!-- Title Bar -->
            <RowDefinition Height="28"/>
            <!-- Menu Bar -->
            <RowDefinition Height="64"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="28"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Custom Title Bar -->
        <Grid Grid.Row="0" Background="White" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" Margin="10,0">
                <TextBlock Text="&#xE118;" Style="{StaticResource IconStyle}" FontSize="16" Foreground="#0078D7"/>
                <TextBlock Text="Synapse Download Manager 2.5" VerticalAlignment="Center" Margin="8,0" FontSize="11" FontFamily="{StaticResource Inter}" Foreground="#444"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <!-- Minimize -->
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeBtn_Click">
                    <TextBlock Text="&#xE921;" Style="{StaticResource IconStyle}" FontSize="16"/>
                </Button>
                <!-- Maximize/Restore -->
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeBtn_Click">
                    <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" Style="{StaticResource IconStyle}" FontSize="16"/>
                </Button>
                <!-- Close -->
                <Button Style="{StaticResource CloseButtonStyle}" x:Name="CloseBtn" Click="CloseBtn_Click">
                    <TextBlock Text="&#xE8BB;" Style="{StaticResource IconStyle}" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Menu Bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#CCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Tasks" Style="{StaticResource MenuBarButtonStyle}"/>
                <Button Content="File" Style="{StaticResource MenuBarButtonStyle}"/>
                <Button Content="Downloads" Style="{StaticResource MenuBarButtonStyle}"/>
                <Button Content="View" Style="{StaticResource MenuBarButtonStyle}"/>
                <Button Content="Help" Style="{StaticResource MenuBarButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- 3. Toolbar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#CCC" BorderThickness="0,1" Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Add URL" Click="AddUrlBtn_Click">
                    <TextBlock Text="&#xE710;" Style="{StaticResource IconStyle}" Foreground="#2E7D32"/>
                </Button>
                <!-- Added UrlInputBox so code-behind can reference it -->

                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Add Torrent">
                    <TextBlock Text="&#xE1CE;" Style="{StaticResource IconStyle}" Foreground="#0078D7"/>
                </Button>

                <Separator Width="1" Margin="4,8" Background="#DDD"/>

                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Resume">
                    <TextBlock Text="&#xE768;" Style="{StaticResource IconStyle}" Foreground="#0078D7"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Stop">
                    <TextBlock Text="&#xE769;" Style="{StaticResource IconStyle}" Foreground="#FF8F00"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Delete">
                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconStyle}" Foreground="#D32F2F"/>
                </Button>

                <Separator Width="1" Margin="4,8" Background="#DDD"/>

                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Options">
                    <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" Foreground="#666"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Tag="Schedule">
                    <TextBlock Text="&#xE787;" Style="{StaticResource IconStyle}" Foreground="#3F51B5"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- 4. Main Content Area -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#F9F9F9" BorderBrush="#CCC" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock Text="COLLECTIONS" DockPanel.Dock="Top" Margin="16,12" FontSize="10" FontWeight="Bold" Foreground="#999" FontFamily="{StaticResource Inter}"/>
                    <ListBox Background="Transparent" BorderThickness="0" SelectedIndex="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="16,8"/>
                                <Setter Property="FontFamily" Value="{StaticResource Inter}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Style="{StaticResource IconStyle}" FontSize="18" Margin="0,0,12,0" Foreground="{TemplateBinding Foreground}"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#0078D7"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EBEBEB"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#005A9E"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Content="All Downloads" Tag="&#xE896;"/>
                        <ListBoxItem Content="Unfinished" Tag="&#xE9A1;"/>
                        <ListBoxItem Content="Finished" Tag="&#xE930;"/>
                        <ListBoxItem Content="Torrents" Tag="&#xE7B8;"/>
                        <ListBoxItem Content="Compressed" Tag="&#xE8B8;"/>
                        <ListBoxItem Content="Programs" Tag="&#xE943;"/>
                        <ListBoxItem Content="Music" Tag="&#xE189;"/>
                        <ListBoxItem Content="Video" Tag="&#xE714;"/>
                    </ListBox>
                </DockPanel>
            </Border>
            <!-- Data Grid -->
            <DataGrid Grid.Column="1" Background="White" BorderThickness="0" 
                      AutoGenerateColumns="False" HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                      HorizontalGridLinesBrush="#F5F5F5"
                      CanUserAddRows="False"
                      FontFamily="{StaticResource Inter}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F8F8"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#666"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#EEE"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="FILE NAME" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="10,4">
                                    <TextBlock Text="&#xE160;" Style="{StaticResource IconStyle}" FontSize="16" Foreground="#0078D7" Margin="0,0,8,0"/>
                                    <TextBlock Text="windows_update_kb503.msi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="SIZE" Width="100" Binding="{Binding Size}" FontFamily="{StaticResource JetBrainsMono}"/>
                    <DataGridTemplateColumn Header="STATUS" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E3F2FD" CornerRadius="2" Padding="6,2" HorizontalAlignment="Left" Margin="10,0">
                                    <TextBlock Text="DOWNLOADING" FontSize="9" FontWeight="Bold" Foreground="#0D47A1"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="SPEED" Width="100" Binding="{Binding Speed}" FontFamily="{StaticResource JetBrainsMono}" Foreground="#0078D7"/>
                    <DataGridTemplateColumn Header="PROGRESS" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,0">
                                    <ProgressBar Value="65" Height="6" Background="#EEE" Foreground="#0078D7" BorderThickness="0"/>
                                    <TextBlock Text="65.4%" FontSize="10" TextAlignment="Right" Foreground="#999" FontFamily="{StaticResource JetBrainsMono}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 5. Status Bar -->
        <Border Grid.Row="4" Background="White" BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="12,0">
            <!-- Use Grid to guarantee correct left/right layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7C3;" Style="{StaticResource IconStyle}" FontSize="14" Foreground="#888"/>
                    <TextBlock Text="Queue: Global" VerticalAlignment="Center" FontSize="10" Margin="6,0,20,0" Foreground="#666" FontFamily="{StaticResource Inter}"/>
                    <TextBlock Text="&#xE8EF;" Style="{StaticResource IconStyle}" FontSize="14" Foreground="#888"/>
                    <TextBlock Text="12 Tasks" VerticalAlignment="Center" FontSize="10" Margin="6,0" Foreground="#666" FontFamily="{StaticResource Inter}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="&#xE943;" Style="{StaticResource IconStyle}" FontSize="14" Foreground="#0078D7"/>
                    <TextBlock Text="MULTI-THREADED ENGINE" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="#0078D7" Margin="6,0" FontFamily="{StaticResource Inter}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>